{
  "name": "ghazi-resturent",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "backend:dev": "npm run dev --prefix backend",
    "dev:all": "npx concurrently -n api,site,admin -c green,blue,orange \"npm run backend:dev\" \"npm run dev\" \"npm run admin:dev\"",
    "admin:dev": "npm run dev --prefix admin",
    "build": "npm run pwa:icons && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "pwa:icons": "node scripts/generate-pwa-icons.mjs",
    "deploy:aws": "node scripts/deploy-aws.mjs",
    "aws:stack": "aws cloudformation deploy --template-file aws/cloudformation.yaml --stack-name ghazi-restaurant --parameter-overrides ProjectName=ghazi-restaurant"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.3.1",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0"
  }
}
